<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Animly — La plateforme des pros du monde animal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
  </style>
</head>
<body class="bg-white text-gray-800">

  <!-- NAVBAR -->
  <nav class="bg-white border-b border-gray-100 px-6 py-4 flex justify-between items-center">
    <span class="text-2xl font-extrabold text-green-600">🐾 Animly</span>
    <a href="#inscription" class="bg-green-600 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-green-700 transition">Rejoindre gratuitement</a>
  </nav>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-green-50 to-green-100 px-6 py-20 text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight max-w-3xl mx-auto">
      Gérez vos rendez-vous.<br/>Gagnez de nouveaux clients.<br/>
      <span class="text-green-600">Gratuitement.</span>
    </h1>
    <p class="mt-6 text-lg md:text-xl text-gray-600 max-w-2xl mx-auto">
      Animly est la première plateforme dédiée aux professionnels du monde animal — toiletteurs, pet-sitters, éducateurs canins. Rejoignez les premiers professionnels de <strong>Lyon, Bordeaux et Nantes</strong>.
    </p>
    <a href="#inscription" class="mt-8 inline-block bg-orange-600 text-white px-8 py-4 rounded-full text-lg font-bold hover:bg-orange-700 transition shadow-lg">
      Je rejoins la liste d'attente →
    </a>
    <p class="mt-4 text-sm text-gray-500">Gratuit • Sans engagement • Lancement en 2025</p>
  </section>

  <!-- PROBLÈME / SOLUTION -->
  <section class="px-6 py-16 bg-white">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Vous reconnaissez-vous ?</h2>
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <div class="bg-gray-50 rounded-2xl p-6 text-center">
        <div class="text-4xl mb-4">📒</div>
        <p class="text-red-500 font-semibold mb-2">Agenda papier débordé</p>
        <p class="text-gray-500 text-sm mb-4">Doubles réservations, oublis, perte de temps...</p>
        <div class="text-green-600 font-semibold">✓ Gestion en ligne simple</div>
        <p class="text-gray-500 text-sm mt-1">Tout centralisé, accessible partout, depuis votre téléphone.</p>
      </div>
      <div class="bg-gray-50 rounded-2xl p-6 text-center">
        <div class="text-4xl mb-4">👻</div>
        <p class="text-red-500 font-semibold mb-2">Clients qui n'arrivent pas</p>
        <p class="text-gray-500 text-sm mb-4">Les no-shows vous coûtent du temps et de l'argent.</p>
        <div class="text-green-600 font-semibold">✓ Rappels automatiques</div>
        <p class="text-gray-500 text-sm mt-1">SMS et notifications envoyés automatiquement avant chaque RDV.</p>
      </div>
      <div class="bg-gray-50 rounded-2xl p-6 text-center">
        <div class="text-4xl mb-4">🌫️</div>
        <p class="text-red-500 font-semibold mb-2">Invisible sur internet</p>
        <p class="text-gray-500 text-sm mb-4">Les nouveaux clients ne vous trouvent pas.</p>
        <div class="text-green-600 font-semibold">✓ Profil visible par des milliers de propriétaires</div>
        <p class="text-gray-500 text-sm mt-1">Votre fiche professionnelle accessible à tous les propriétaires de votre ville.</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="px-6 py-16 bg-green-50">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Tout ce dont vous avez besoin</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      <div class="bg-white rounded-2xl p-6 shadow-sm text-center">
        <div class="text-4xl mb-3">📅</div>
        <h3 class="font-bold text-gray-900 mb-1">Agenda en ligne</h3>
        <p class="text-gray-500 text-sm">Prise de RDV 24h/24, même quand vous dormez.</p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm text-center">
        <div class="text-4xl mb-3">👥</div>
        <h3 class="font-bold text-gray-900 mb-1">Profil professionnel</h3>
        <p class="text-gray-500 text-sm">Visible par les propriétaires près de chez vous.</p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm text-center">
        <div class="text-4xl mb-3">🔔</div>
        <h3 class="font-bold text-gray-900 mb-1">Rappels automatiques</h3>
        <p class="text-gray-500 text-sm">Fini les no-shows. Vos clients sont prévenus.</p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm text-center">
        <div class="text-4xl mb-3">📊</div>
        <h3 class="font-bold text-gray-900 mb-1">Statistiques</h3>
        <p class="text-gray-500 text-sm">Suivez votre activité et votre croissance.</p>
      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section class="px-6 py-16 bg-white">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-4">Tarifs simples et transparents</h2>
    <p class="text-center text-gray-500 mb-12">Commencez gratuitement. Évoluez à votre rythme.</p>
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Gratuit -->
      <div class="border border-gray-200 rounded-2xl p-8 text-center">
        <h3 class="text-xl font-bold text-gray-900 mb-2">Gratuit</h3>
        <div class="text-4xl font-extrabold text-gray-900 mb-1">0€</div>
        <div class="text-gray-400 text-sm mb-6">/mois</div>
        <ul class="text-gray-600 text-sm space-y-2 mb-8">
          <li>✓ Profil de base</li>
          <li>✓ 10 RDV/mois</li>
          <li>✓ Visible sur la plateforme</li>
        </ul>
        <a href="#inscription" class="block w-full border border-green-600 text-green-600 py-3 rounded-full font-semibold hover:bg-green-50 transition">Commencer</a>
      </div>
      <!-- Standard -->
      <div class="border-2 border-green-600 rounded-2xl p-8 text-center relative shadow-lg">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-orange-600 text-white text-xs font-bold px-4 py-1 rounded-full">⭐ POPULAIRE</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Standard</h3>
        <div class="text-4xl font-extrabold text-green-600 mb-1">29€</div>
        <div class="text-gray-400 text-sm mb-6">/mois</div>
        <ul class="text-gray-600 text-sm space-y-2 mb-8">
          <li>✓ RDV illimités</li>
          <li>✓ Rappels SMS automatiques</li>
          <li>✓ Statistiques d'activité</li>
          <li>✓ Profil mis en avant</li>
        </ul>
        <a href="#inscription" class="block w-full bg-green-600 text-white py-3 rounded-full font-semibold hover:bg-green-700 transition">Choisir Standard</a>
      </div>
      <!-- Premium -->
      <div class="border border-gray-200 rounded-2xl p-8 text-center">
        <h3 class="text-xl font-bold text-gray-900 mb-2">Premium</h3>
        <div class="text-4xl font-extrabold text-gray-900 mb-1">59€</div>
        <div class="text-gray-400 text-sm mb-6">/mois</div>
        <ul class="text-gray-600 text-sm space-y-2 mb-8">
          <li>✓ Tout Standard inclus</li>
          <li>✓ Priorité dans les résultats</li>
          <li>✓ Support dédié</li>
          <li>✓ Fonctionnalités avancées</li>
        </ul>
        <a href="#inscription" class="block w-full border border-green-600 text-green-600 py-3 rounded-full font-semibold hover:bg-green-50 transition">Choisir Premium</a>
      </div>
    </div>
  </section>

  <!-- FORMULAIRE -->
  <section id="inscription" class="px-6 py-16 bg-gradient-to-br from-green-600 to-green-700">
    <div class="max-w-xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-2">Rejoignez les pionniers 🐾</h2>
      <p class="text-green-100 text-center mb-8">Inscription gratuite — nous vous contacterons en priorité au lancement dans votre ville.</p>
      <form id="animly-form" action="https://formspree.io/f/xpwzgvka" method="POST" class="bg-white rounded-2xl p-8 shadow-xl space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Prénom & Nom</label>
          <input type="text" name="nom" required placeholder="Marie Dupont" class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email professionnel</label>
          <input type="email" name="email" required placeholder="marie@monttoilettage.fr" class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Votre profession</label>
          <select name="profession" required class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
            <option value="">Sélectionnez votre métier</option>
            <option value="toiletteur">Toiletteur / Toiletteuse</option>
            <option value="petsitter">Pet-sitter</option>
            <option value="educateur">Éducateur/trice canin(e)</option>
            <option value="pension">Pension animaux</option>
            <option value="autre">Autre</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Votre ville</label>
          <select name="ville" required class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
            <option value="">Sélectionnez votre ville</option>
            <option value="lyon">Lyon</option>
            <option value="bordeaux">Bordeaux</option>
            <option value="nantes">Nantes</option>
            <option value="autre">Autre</option>
          </select>
        </div>
        <button type="submit" class="w-full bg-orange-600 text-white py-4 rounded-xl font-bold text-base hover:bg-orange-700 transition shadow">
          Je rejoins Animly gratuitement 🐾
        </button>
      </form>
      <div id="form-success" class="hidden bg-white rounded-2xl p-8 text-center shadow-xl">
        <div class="text-5xl mb-4">🐾</div>
        <h3 class="text-xl font-bold text-green-700 mb-2">Merci !</h3>
        <p class="text-gray-600">Nous vous contacterons en priorité pour le lancement dans votre ville.</p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 text-center px-6 py-8">
    <p class="text-white font-bold text-xl mb-2">🐾 Animly</p>
    <p class="text-sm">© 2025 Animly — Tous droits réservés</p>
    <p class="text-sm mt-1"><a href="mailto:contact@animly.fr" class="hover:text-white transition">contact@animly.fr</a></p>
  </footer>

  <script>
    const form = document.getElementById('animly-form');
    const success = document.getElementById('form-success');
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const data = new FormData(form);
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' }
        });
        if (res.ok) {
          form.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          alert('Une erreur est survenue. Veuillez réessayer.');
        }
      } catch {
        alert('Une erreur est survenue. Veuillez réessayer.');
      }
    });
  </script>

</body>
</html>
